{
  "name": "next-subscription-manager",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "dotenv -e .env -- tsx scripts/seed.ts",
    "db:migrate:email": "dotenv -e .env -- tsx prisma/migrations/add-email-to-users.ts",
    "reset-password": "dotenv -e .env -- tsx scripts/reset-password.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "test": "tsx --test tests/**/*.test.ts",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.9",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.1.1",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.24.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "autoprefixer": "^10.4.23",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.14",
    "prettier": "^3.9.5",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "defu@<=6.1.4": "6.1.5",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.10": "8.5.14",
      "@peculiar/asn1-android": "2.8.0",
      "@peculiar/asn1-ecc": "2.8.0",
      "@peculiar/asn1-rsa": "2.8.0",
      "@peculiar/asn1-schema": "2.8.0",
      "@peculiar/asn1-x509": "2.8.0"
    }
  }
}
